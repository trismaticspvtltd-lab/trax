PORT=3001
TCP_PORT=8808

DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=SejuAnu@123
DB_DATABASE=traxlogi

JWT_SECRET=TRAXLOGI_JWT_SECRET_2024_SECURE_KEY
JWT_EXPIRATION=7d

# AWS S3 — replace with your actual credentials
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_S3_BUCKET=traxlogi-recordings

# JT1078 Media Server — local port the media TCP server listens on
MEDIA_SERVER_PORT=8880
# Public hostname devices use to reach the media server (ngrok host only, no protocol prefix)
MEDIA_SERVER_PUBLIC_IP=0.tcp.in.ngrok.io
# External ngrok port that forwards to MEDIA_SERVER_PORT (28996 → localhost:8880)
MEDIA_SERVER_PUBLIC_PORT=28996

IOPGPS_API_URL=https://api.iopgps.com
IOPGPS_API_KEY=

# JT808 ngrok tunnel (current session → localhost:8808)
NGROK_TCP_URL=tcp://0.tcp.in.ngrok.io:17082

BASE_URL=http://localhost:3001
# Backend now serves the frontend on the same port, so frontend and API share the same origin.
# CORS is not triggered for same-origin requests. Set this to your EC2 URL if you ever split them.
FRONTEND_URL=http://localhost:3001
